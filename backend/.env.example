# Backend server
PORT=5000
JWT_SECRET=change-me-in-production
ADMIN_CODE=admin-secret
MAX_PANTRY_ITEMS=200

# If true, API starts without a DB (demo/mock mode)
SKIP_DB=false

# Preferred option: full Postgres URL
# Example:
# DATABASE_URL=postgresql://postgres:postgres@localhost:5432/pov_cooking
DATABASE_URL=

# Alternate option: discrete Postgres settings (used when DATABASE_URL is empty)
PGHOST=localhost
PGPORT=5432
PGUSER=postgres
PGPASSWORD=postgres
PGDATABASE=pov_cooking

# Optional for managed Postgres (Neon/Supabase/Render, etc.)
# true|1|require => enable SSL with relaxed cert check
DB_SSL=false
